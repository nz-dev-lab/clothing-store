# Local development environment variables
# Copy this to .env and fill in your values
# .env is gitignored — never commit real credentials

MYSQL_ROOT_PASSWORD=rootpass_change_me
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=wppass_change_me

# WordPress site URL (used by WP-CLI scripts)
WP_SITEURL=http://localhost:8080
WP_HOME=http://localhost:8080

# Admin credentials for WP-CLI setup script
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin_change_me
WP_ADMIN_EMAIL=your@email.com

# WooCommerce REST API keys (generate these from WP Admin after setup)
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
