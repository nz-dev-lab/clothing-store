{
  "name": "clothing-store-child",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "vite build && tailwindcss -i src/css/main.css -o assets/css/main.css --minify",
    "dev": "concurrently \"vite build --watch\" \"tailwindcss -i src/css/main.css -o assets/css/main.css --watch\""
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
